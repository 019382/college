class Personagem:
    EMOJIS = {
        "Barbaro": "⚔️",
        "Mago": "🧙",
        "Assassino": "🗡️️️",
        "Paladino": "🛡️"
    }

    #inicializador
    def __init__(self, nome, sexo):
        self.nome = nome
        self.sexo = sexo

    def __str__(self):
        atributos = vars(self)
        
        classe = self.__class__.__name__
        emoji = self.EMOJIS.get(classe, "👤")

        texto = f"{emoji} ----- STATUS ----- {emoji}\n"
        texto += f"Classe: {classe}\n"

        for chave, valor in atributos.items():
            texto += f"{chave}: {valor}\n"

        return texto


