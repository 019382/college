import random
import time


class Personagem:
    EMOJIS = {
        "Barbaro": "⚔️",
        "Mago": "🧙",
        "Assassino": "🗡️",
        "Paladino": "🛡️"
    }

    def __init__(self, nome, sexo):
        self.nome = nome
        self.sexo = sexo
        self.lista_ataques = []  

    def __str__(self):
        atributos = vars(self)
        classe = self.__class__.__name__
        emoji = self.EMOJIS.get(classe, "👤")

        texto = f"{emoji} ----- STATUS ----- {emoji}\n"
        texto += f"Classe: {classe}\n"
        for chave, valor in atributos.items():
            if chave != "lista_ataques":
                texto += f"{chave}: {valor}\n"
        return texto

    def receber_dano(self, dano):
        self.vida -= dano
        if self.vida < 0:
            self.vida = 0

    def esta_vivo(self):
        return self.vida > 0


def rolar_dado():
    
    valor = random.randint(1, 6)

    if valor == 1:
        return 0.0, "❌ ERROU O ATAQUE!", valor
    elif valor in (2, 3):
        return 1.0, "🗯️ Dano normal", valor
    elif valor in (4, 5):
        return 1.5, "🔥 Dano bom", valor
    else:  
        return 2.0, "💥 DANO CRÍTICO!", valor


class Barbaro(Personagem):
    def __init__(self, nome, sexo):
        super().__init__(nome, sexo)
        self.vida = 200
        self.defesa = 20
        self.stamina = 200
        self.forca = 0.50
        self.velocidade = 20.0
        self.agilidade = 35
        self.lista_ataques = [self.arremessar_machado, self.machado_rapido]

    def arremessar_machado(self, alvo, multiplicador=1.0):
        custo = 60
        if self.stamina >= custo:
            self.stamina -= custo
            dano = self.forca * 70 * multiplicador
            print(f"{self.nome} usou Arremessar Machado!")
            alvo.receber_dano(dano)
            return dano
        else:
            print(f"{self.nome} não possui stamina suficiente! (usou ataque básico)")
            return self.machado_rapido(alvo, multiplicador)

    def machado_rapido(self, alvo, multiplicador=1.0):
        custo = 10
        if self.stamina >= custo:
            self.stamina -= custo
            dano = self.forca * 40 * multiplicador
            print(f"{self.nome} usou Machado Rápido!")
            alvo.receber_dano(dano)
            return dano
        else:
            print(f"{self.nome} está exausto e não consegue atacar!")
            return 0


