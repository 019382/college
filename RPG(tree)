class No:
    def __init__(self, personagem=None, esquerda=None, direita=None):
        self.personagem = personagem
        self.esquerda = esquerda
        self.direita = direita

    def eh_folha(self):
        return self.esquerda is None and self.direita is None


def construir_arvore(participantes):
    if len(participantes) != 4:
        raise ValueError("O torneio precisa de exatamente 4 personagens.")

    pers_a1 = No(personagem=participantes[0])
    pers_a2 = No(personagem=participantes[1])
    pers_b1 = No(personagem=participantes[2])
    pers_b2 = No(personagem=participantes[3])

    primeira_batalha_a = No(esquerda=pers_a1, direita=pers_a2)
    primeira_batalha_b = No(esquerda=pers_b1, direita=pers_b2)

    raiz_final = No(esquerda=primeira_batalha_a, direita=primeira_batalha_b)

    return raiz_final


def batalha(p1, p2):
    print("\n" + "=" * 50)
    print(f"⚔️  {p1.nome} ({p1.__class__.__name__}) VS {p2.nome} ({p2.__class__.__name__})  ⚔️")
    print("=" * 50)
    time.sleep(0.5)

    turno = 1
    atacante, defensor = (p1, p2) if p1.velocidade >= p2.velocidade else (p2, p1)

    while p1.esta_vivo() and p2.esta_vivo():
        print(f"\n--- Turno {turno} ---")

        if hasattr(atacante, "stamina"):
            atacante.stamina = min(atacante.stamina + 15, 200)
        if hasattr(atacante, "mana"):
            atacante.mana = min(atacante.mana + 15, 150)

        multiplicador, descricao, valor_dado = rolar_dado()
        print(f"🎲 {atacante.nome} rolou o dado: {valor_dado} -> {descricao}")

        ataque = random.choice(atacante.lista_ataques)
        ataque(defensor, multiplicador)

        print(f"❤️ {defensor.nome}: {defensor.vida:.1f} de vida restante")

        if not defensor.esta_vivo():
            break

        atacante, defensor = defensor, atacante
        turno += 1
        time.sleep(0.3)

    vencedor = p1 if p1.esta_vivo() else p2
    perdedor = p2 if vencedor is p1 else p1
    print(f"\n🏆 {vencedor.nome} venceu a batalha contra {perdedor.nome}!\n")
    return vencedor


def disputar_torneio(no):
    if no.eh_folha():
        return no.personagem

    vencedor_esq = disputar_torneio(no.esquerda)
    vencedor_dir = disputar_torneio(no.direita)

    no.personagem = batalha(vencedor_esq, vencedor_dir)
    return no.personagem


def escolher_sexo():
    print("Escolha o sexo do seu personagem:")
    print("1 - Feminino")
    print("2 - Masculino")
    escolha = input("Digite a opção: ")

    if escolha == "1":
        return "Feminino"
    elif escolha == "2":
        return "Masculino"
    else:
        print("Opção inválida, definindo como 'Indefinido'.")
        return "Indefinido"


def criar_personagem(numero):
    classes = {
        "1": Barbaro,
        "2": Mago,
        "3": Assassino,
        "4": Paladino
    }

    print(f"\n--- Criando Personagem {numero} ---")
    escolha = input(
        "1-Barbaro\n"
        "2-Mago\n"
        "3-Assassino\n"
        "4-Paladino\n"
        "Escolha: "
    )

    while escolha not in classes:
        print("Classe inválida, tente novamente.")
        escolha = input("Escolha: ")

    nome = input("Nome: ")
    sexo = escolher_sexo()

    return classes[escolha](nome, sexo)


def criar_personagens_automaticos():
    
    nomes = ["Olaf", "Veigar", "Shaco", "Leona"]
    classes = [Barbaro, Mago, Assassino, Paladino]
    sexos = ["Masculino", "Feminino", "Masculino", "Feminino"]

    return [classes[i](nomes[i], sexos[i]) for i in range(4)]


def main():
    print("=" * 50)

    modo = input("Criar personagens manualmente (1) ou automático (2)? ")

    if modo == "1":
        participantes = [criar_personagem(i + 1) for i in range(4)]
    else:
        participantes = criar_personagens_automaticos()

    print("\n--- PARTICIPANTES ---")
    for p in participantes:
        print(p)

    raiz = construir_arvore(participantes)
    campeao = disputar_torneio(raiz)

    print("\n" + "★" * 50)
    print(f"👑 CAMPEÃO DO TORNEIO: {campeao.nome} ({campeao.__class__.__name__}) 👑")
    print("★" * 50)


if __name__ == "__main__":
    main()
    
